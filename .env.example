# Database (matches db/docker-compose.yaml)
DB_HOST=localhost
DB_PORT=15432
DB_NAME=mock_trader
DB_USER=postgres
DB_PASSWORD=postgres

# Binance
BINANCE_BASE_URL=https://api.binance.com
SYMBOL=BTCUSDT

# Trading
DEFAULT_AMOUNT_USD=10
MONITOR_INTERVAL_SECONDS=60
FEE_PCT=0.001

# Logging (ERROR | WARNING | INFO | DEBUG | VERBOSE)
LOG_LEVEL=INFO
LOG_DIR=logs
