# ── Database ─────────────────────────────────────────────────
# DB_HOST and DB_PORT are overridden by docker-compose.yaml
# to use the internal 'postgres' service name.
DB_NAME=mock_trader
DB_USER=postgres
DB_PASSWORD=postgres
# Port exposed on the HOST (for external access / debugging)
DB_PORT_HOST=15432

# ── Binance ──────────────────────────────────────────────────
BINANCE_BASE_URL=https://api.binance.com
SYMBOL=BTCUSDT

# ── Trading ──────────────────────────────────────────────────
DEFAULT_AMOUNT_USD=10
MONITOR_INTERVAL_SECONDS=60
FEE_PCT=0.001

# ── Logging (ERROR | WARNING | INFO | DEBUG | VERBOSE) ───────
LOG_LEVEL=INFO
LOG_DIR=logs
